# Neon Postgres (region: aws-eu-central-1)
# Pooled connection (used by the app at runtime via @prisma/adapter-neon).
DATABASE_URL=
# Direct connection (used by the Prisma CLI for migrations and introspection).
DIRECT_URL=

# Better Auth — generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3006

# Public site URL — same as BETTER_AUTH_URL in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3006
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3006

# Bootstrap admin (used by `npm run db:seed`)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Cloudinary — URL de conexión con formato:
# `cloudinary://api_key:api_secret@cloud_name`
# Ver dashboard de Cloudinary → Account Details. Usado server-side por
# `src/lib/cloudinary.ts` para upload/delete de imágenes geo y de fichas.
CLOUDINARY_URL=

# Upload preset firmado para uploads directos del cliente a Cloudinary
# (v0.3-geo-c). Cada developer/entorno debe crear su propio preset en
# el dashboard de Cloudinary con `Signing Mode = Signed`. Restricciones
# de formato/tamaño se configuran del lado de Cloudinary; el cliente
# las complementa con validación local. Ver AGENTS.md sección "Upload
# preset firmado para uploads directos del cliente".
CLOUDINARY_UPLOAD_PRESET=

# DeepL — traducción automática del contenido editorial al guardar.
# Free Plan: 500k chars/mes. El SDK detecta Free vs Pro por sufijo `:fx`.
# Ver AGENTS.md sección "i18n del contenido editorial". Activo desde
# v0.3-geo-b — `src/lib/deepl.ts` hace throw eager si la variable no
# está seteada.
DEEPL_API_KEY=

# Resend — alertas por email (cuota DeepL al 80%, otros eventos futuros).
# NO implementado todavía — placeholder. Cuando se implementen las
# alertas, el `console.warn` del 80% en `src/lib/deepl.ts` pasa a email.
RESEND_API_KEY=
