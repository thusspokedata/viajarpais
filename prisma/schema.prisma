model Category {
  id               String            @id @default(cuid())
  slug             String            @unique
  nameEs           String
  nameEn           String
  namePtBr         String
  nameSingularEs   String
  nameSingularEn   String
  nameSingularPtBr String
  icon             String?
  order            Int               @default(0)
  listings         ListingCategory[]

  @@index([order])
}

model Listing {
  id   String @id @default(cuid())
  name String
  slug String @unique

  /**
   * `descriptionEs` viene del rename de `description` (preservar
   * contenido en migracion). Tagline + i18n agregados para alinear con
   * el patron de los niveles geograficos (DeepL en v0.3-geo-b).
   */
  taglineEs                  String?
  taglineEn                  String?
  taglinePtBr                String?
  taglineEnSource            TranslationSource @default(NONE)
  taglinePtBrSource          TranslationSource @default(NONE)
  taglineEnTranslatedAt      DateTime?
  taglinePtBrTranslatedAt    DateTime?
  // `*PendingRetry` lo activa la server action de update cuando dispara
  // DeepL para este campo y la traducción falla (3 retries agotados o
  // cuota mensual excedida). El admin muestra banner + botón "Reintentar
  // ahora" mientras este flag esté en true. Se baja a false cuando la
  // traducción se completa o el editor edita la versión manualmente.
  taglineEnPendingRetry      Boolean           @default(false)
  taglinePtBrPendingRetry    Boolean           @default(false)
  // `*EsAtTranslation*` guardan un snapshot del `taglineEs` en el
  // momento en que se persistió la traducción correspondiente. El
  // panel admin compara `current.taglineEs` contra este snapshot para
  // decidir si el texto base cambió desde la última revisión — el
  // banner de drift anterior se basaba en timestamps (`translatedAt <
  // updatedAt`) y disparaba falsos positivos al cambiar campos no
  // traducibles (metaTitleEs, etc.) o incluso 1s después de marcar
  // REVIEWED por colisión ms. Null = sin snapshot (rows pre-migración
  // backfilleados solo si source era REVIEWED/HUMAN).
  taglineEsAtTranslationEn   String?
  taglineEsAtTranslationPtBr String?

  descriptionEs                  String
  descriptionEn                  String?
  descriptionPtBr                String?
  descriptionEnSource            TranslationSource @default(NONE)
  descriptionPtBrSource          TranslationSource @default(NONE)
  descriptionEnTranslatedAt      DateTime?
  descriptionPtBrTranslatedAt    DateTime?
  // Ver `taglineEnPendingRetry` arriba — misma semántica.
  descriptionEnPendingRetry      Boolean           @default(false)
  descriptionPtBrPendingRetry    Boolean           @default(false)
  // Ver `taglineEsAtTranslationEn` arriba — misma semántica.
  descriptionEsAtTranslationEn   String?
  descriptionEsAtTranslationPtBr String?

  /**
   * Geografia: `regionId` esta denormalizado para queries publicas de
   * region (ej. listar fichas de una region sin JOIN de 3 niveles). Se
   * resuelve automaticamente desde la cadena Locality -> Department ->
   * Province -> Region en `createListing` y en `updateListing` (solo
   * cuando cambia `localityId`). NO editable por el editor.
   */
  regionId     String
  region       Region     @relation(fields: [regionId], references: [id])
  provinceId   String
  province     Province   @relation(fields: [provinceId], references: [id])
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  localityId   String
  locality     Locality   @relation(fields: [localityId], references: [id])
  address      String
  lat          Decimal?   @db.Decimal(10, 7)
  lng          Decimal?   @db.Decimal(10, 7)

  phone    String?
  whatsapp String?
  email    String?
  website  String?

  instagram String?
  facebook  String?
  tiktok    String?
  youtube   String?

  priceRange     PriceRange?
  openingHours   Json?
  paymentMethods PaymentMethod[]
  languages      SpokenLanguage[]

  attributes Json?

  metaTitleEs         String?
  metaTitleEn         String?
  metaTitlePtBr       String?
  metaDescriptionEs   String?
  metaDescriptionEn   String?
  metaDescriptionPtBr String?

  categories ListingCategory[]
  images     ListingImage[]

  status        ListingStatus @default(DRAFT)
  tier          ListingTier   @default(FREE)
  paymentStatus PaymentStatus @default(NONE)

  verifiedAt    DateTime?
  verifiedUntil DateTime?
  verifiedById  String?
  verifiedBy    User?     @relation("VerifiedListings", fields: [verifiedById], references: [id])

  createdById    String
  createdBy      User      @relation("CreatedListings", fields: [createdById], references: [id])
  lastEditedById String?
  lastEditedBy   User?     @relation("LastEditedListings", fields: [lastEditedById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?
  // verifiedAt: ver migracion add_listing_data_integrity_fixes —
  // reemplazado por dos indices parciales (verified vs unverified)
  // que Prisma no puede expresar via @@index.

  @@index([provinceId])
  @@index([departmentId])
  @@index([localityId])
  @@index([regionId])
  @@index([regionId, status])
  @@index([status])
  @@index([tier])
  @@index([updatedAt(sort: Desc)])
}

model ListingCategory {
  id         String   @id @default(cuid())
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  isPrimary  Boolean  @default(false)

  @@unique([listingId, categoryId])
  @@index([categoryId])
  @@index([listingId, isPrimary])
}

model ListingImage {
  id                 String   @id @default(cuid())
  listingId          String
  listing            Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  cloudinaryPublicId String   @unique
  url                String
  caption            String?
  altText            String?
  order              Int      @default(0)
  isPrimary          Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@index([listingId, order])
  @@index([listingId, isPrimary])
}

/**
 * Imágenes asociadas a niveles geográficos. Mismo shape que
 * `ListingImage`. Constraint "una sola primary por padre" se enforza
 * en server actions (no en DB con partial unique como `ListingCategory`)
 * porque la lógica de set-primary aquí es atómica: la transacción
 * setea isPrimary=false a las hermanas y true a la elegida.
 */
model RegionImage {
  id                 String   @id @default(cuid())
  regionId           String
  region             Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  cloudinaryPublicId String   @unique
  url                String
  caption            String?
  altText            String?
  order              Int      @default(0)
  isPrimary          Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@index([regionId, order])
  @@index([regionId, isPrimary])
}

model ProvinceImage {
  id                 String   @id @default(cuid())
  provinceId         String
  province           Province @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  cloudinaryPublicId String   @unique
  url                String
  caption            String?
  altText            String?
  order              Int      @default(0)
  isPrimary          Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@index([provinceId, order])
  @@index([provinceId, isPrimary])
}

model DepartmentImage {
  id                 String     @id @default(cuid())
  departmentId       String
  department         Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  cloudinaryPublicId String     @unique
  url                String
  caption            String?
  altText            String?
  order              Int        @default(0)
  isPrimary          Boolean    @default(false)
  createdAt          DateTime   @default(now())

  @@index([departmentId, order])
  @@index([departmentId, isPrimary])
}

model LocalityImage {
  id                 String   @id @default(cuid())
  localityId         String
  locality           Locality @relation(fields: [localityId], references: [id], onDelete: Cascade)
  cloudinaryPublicId String   @unique
  url                String
  caption            String?
  altText            String?
  order              Int      @default(0)
  isPrimary          Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@index([localityId, order])
  @@index([localityId, isPrimary])
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          UserRole  @default(MERCHANT)
  sessions      Session[]
  accounts      Account[]

  createdListings    Listing[] @relation("CreatedListings")
  lastEditedListings Listing[] @relation("LastEditedListings")
  verifiedListings   Listing[] @relation("VerifiedListings")

  // Geo: el editor que dejó la última edición de contenido editorial
  // en cada nivel geográfico.
  lastEditedRegions     Region[]     @relation("RegionLastEdited")
  lastEditedProvinces   Province[]   @relation("ProvinceLastEdited")
  lastEditedDepartments Department[] @relation("DepartmentLastEdited")
  lastEditedLocalities  Locality[]   @relation("LocalityLastEdited")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

/**
 * Contador mensual de caracteres consumidos por proveedor de traducción
 * automática (hoy solo DeepL Free plan, 500k chars/mes). Una fila por
 * (`month`, `provider`); `month` es el primer día del mes en formato
 * `YYYY-MM` para que la unicidad sea exacta y el query trivial.
 * Atomicidad del incremento: usamos `prisma.translationUsage.update({
 * where: { month_provider }, data: { charactersUsed: { increment: N } }
 * })` que se compila a `SET charactersUsed = charactersUsed + N` —
 * seguro ante saves concurrentes sin necesidad de transacción
 * explícita. El pre-check de quota acepta una pequeña race (pueden
 * pasarse 1-2 traducciones del cap si dos saves entran en simultáneo
 * con `charactersUsed` justo por debajo del límite) — trade-off
 * documentado en `src/lib/deepl.ts`.
 * Cuando llegue Pro plan o un segundo proveedor, basta con sumar rows
 * de distinto `provider` y mes — sin cambios de schema.
 */
model TranslationUsage {
  id             String   @id @default(cuid())
  month          String
  provider       String   @default("deepl")
  charactersUsed Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([month, provider])
}

/**
 * Single-use nonces para signatures de upload a Cloudinary.
 * Sin esta tabla, la signature que `getUploadSignature` devuelve es
 * válida por ~1h y NO firma el file/filename — un EDITOR con DevTools
 * podía cachear una signature legítima y reusarla para subir N
 * archivos arbitrarios al folder firmado (drain del Free plan 25GB).
 * Flujo:
 * 1. `getUploadSignature` crea un nonce nuevo (`crypto.randomUUID()`)
 * con `usedAt = null`, lo firma como parte del payload Cloudinary
 * `{ timestamp, folder, upload_preset, nonce }`, y lo retorna al
 * cliente.
 * 2. Cliente envía el nonce a Cloudinary (FormData) — Cloudinary lo
 * verifica con la signature (mismatch → 401).
 * 3. Cliente recibe `cloudinaryPublicId` y llama `saveImageMetadata`
 * pasando el nonce.
 * 4. `saveImageMetadata` marca `usedAt = now()` con un update
 * condicional `WHERE usedAt IS NULL` — si dos requests llegan con
 * el mismo nonce, solo uno gana.
 * Garantía: una signature solo puede registrar UN row en DB. Para
 * subir N veces, el cliente necesita pedir N signatures (cada una
 * con su propio nonce). El editor puede igual subir archivos a
 * Cloudinary durante la ventana de la signature, pero solo registra
 * 1 en DB → no drena el plan.
 * Cleanup: cron daily futuro borra rows con `createdAt > 24h` para
 * no acumular basura. Documentado en AGENTS.md.
 */
model UploadSignatureNonce {
  nonce      String    @id
  createdAt  DateTime  @default(now())
  usedAt     DateTime?
  entityType String
  entityId   String

  @@index([usedAt])
  @@index([createdAt])
}
