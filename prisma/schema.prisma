generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
  runtime      = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EDITOR
  MERCHANT
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ListingTier {
  FREE
  PAID
  FEATURED
}

enum PaymentStatus {
  NONE
  ACTIVE
  LAPSED
}

enum PriceRange {
  BUDGET
  MID
  HIGH
  LUXURY
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  MERCADO_PAGO
  TRANSFER
  CRYPTO
}

enum SpokenLanguage {
  ES
  EN
  PT
  FR
  DE
  IT
}

/**
 * Origen de cada traducción de campos editoriales (`tagline*En/PtBr`,
 * `description*En/PtBr`, etc.). La fuente de verdad es siempre español
 * (no se persiste source para `*Es`).
 * - NONE: sin traducir todavía.
 * - MACHINE: generada automáticamente por DeepL al guardar.
 * - REVIEWED: generada por DeepL pero un editor la revisó y validó.
 * - HUMAN: editor escribió la traducción manualmente.
 * Lógica de DeepL = v0.3-geo-b. En v0.3-geo-a este enum solo existe en
 * schema; los campos se llenan en EN/PT-BR cuando se cargue la
 * traducción automática en el siguiente PR.
 */
enum TranslationSource {
  NONE
  MACHINE
  REVIEWED
  HUMAN
}

model Region {
  id        String        @id @default(cuid())
  code      String        @unique
  // Nombres por idioma. `nameEs` viene de la columna `name` original
  // (renombrada en migracion). `nameEn` y `namePtBr` se cargan via seed
  // upsert. Editor NO los modifica desde admin — son hardcoded.
  nameEs    String
  nameEn    String
  namePtBr  String
  order     Int           @default(0)
  provinces Province[]
  listings  Listing[]
  images    RegionImage[]

  // Contenido editorial (nullable; el editor los completa desde admin).
  taglineEs                  String?
  taglineEn                  String?
  taglinePtBr                String?
  taglineEnSource            TranslationSource @default(NONE)
  taglinePtBrSource          TranslationSource @default(NONE)
  taglineEnTranslatedAt      DateTime?
  taglinePtBrTranslatedAt    DateTime?
  // `*PendingRetry` lo activa la server action de update cuando dispara
  // DeepL para este campo y la traducción falla (3 retries agotados o
  // cuota mensual excedida). El admin muestra banner + botón "Reintentar
  // ahora" mientras este flag esté en true. Se baja a false cuando la
  // traducción se completa o el editor edita la versión manualmente.
  taglineEnPendingRetry      Boolean           @default(false)
  taglinePtBrPendingRetry    Boolean           @default(false)
  // `*EsAtTranslation*` guardan un snapshot del `taglineEs` en el
  // momento en que se persistió la traducción correspondiente. El
  // panel admin compara `current.taglineEs` contra este snapshot para
  // decidir si el texto base cambió desde la última revisión — el
  // banner de drift anterior se basaba en timestamps (`translatedAt <
  // updatedAt`) y disparaba falsos positivos al cambiar campos no
  // traducibles (metaTitleEs, etc.) o incluso 1s después de marcar
  // REVIEWED por colisión ms. Null = sin snapshot (rows pre-migración
  // backfilleados solo si source era REVIEWED/HUMAN).
  taglineEsAtTranslationEn   String?
  taglineEsAtTranslationPtBr String?

  descriptionEs                  String?
  descriptionEn                  String?
  descriptionPtBr                String?
  descriptionEnSource            TranslationSource @default(NONE)
  descriptionPtBrSource          TranslationSource @default(NONE)
  descriptionEnTranslatedAt      DateTime?
  descriptionPtBrTranslatedAt    DateTime?
  // Ver `taglineEnPendingRetry` arriba — misma semántica.
  descriptionEnPendingRetry      Boolean           @default(false)
  descriptionPtBrPendingRetry    Boolean           @default(false)
  // Ver `taglineEsAtTranslationEn` arriba — misma semántica.
  descriptionEsAtTranslationEn   String?
  descriptionEsAtTranslationPtBr String?

  metaTitleEs         String?
  metaTitleEn         String?
  metaTitlePtBr       String?
  metaDescriptionEs   String?
  metaDescriptionEn   String?
  metaDescriptionPtBr String?

  // Auditoria. `createdAt` no aplica porque las regiones se crean por
  // seed (idempotente). `updatedAt` y `lastEditedById` se usan para
  // optimistic locking en updateRegion.
  updatedAt      DateTime @updatedAt
  lastEditedById String?
  lastEditedBy   User?    @relation("RegionLastEdited", fields: [lastEditedById], references: [id])

  @@index([order])
}

